{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist-electron",
    "rootDir": "./electron",
    "strict": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmitOnError": true,
    "skipLibCheck": true
  },
  "include": ["electron/**/*.ts"]
}
