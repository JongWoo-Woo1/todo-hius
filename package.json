{
  "name": "project-todo",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run prepare:logs && concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 file:dist/electron/main.js file:dist/electron/preload.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electronmon dist/electron/main.js\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "build:web": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "prepare:logs": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"New-Item -ItemType Directory -Force -Path log | Out-Null\"",
    "clean:logs": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path log) { Remove-Item -LiteralPath log -Recurse -Force }\"",
    "clean:dist": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"foreach ($p in @('dist','dist-electron','release')) { if (Test-Path $p) { Remove-Item -LiteralPath $p -Recurse -Force } }\"",
    "clean:release": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path dist\\\\release) { Remove-Item -LiteralPath dist\\\\release -Recurse -Force }\"",
    "clean:release-extras": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path dist\\\\release\\\\win-unpacked) { Remove-Item -LiteralPath dist\\\\release\\\\win-unpacked -Recurse -Force }; if (Test-Path dist\\\\release\\\\builder-debug.yml) { Remove-Item -LiteralPath dist\\\\release\\\\builder-debug.yml -Force }\"",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:installer": "npm run clean:release && npm run build && electron-builder --win nsis && npm run clean:release-extras"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "electronmon": "^2.0.4",
    "typescript": "^5.8.3",
    "vite": "^7.1.0",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1"
  },
  "electronmon": {
    "patterns": [
      "!**/hius-dt-jw-todo/**",
      "!**/dist/electron/**",
      "!**/log/**",
      "!**/*.todo"
    ]
  },
  "build": {
    "appId": "com.hius.todo",
    "productName": "HIUS Todo",
    "directories": {
      "output": "dist/release"
    },
    "files": [
      "dist/renderer/**/*",
      "dist/electron/**/*",
      "!dist/electron/hius-dt-jw-todo/**",
      "!dist/release/**",
      "!**/*.todo",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HIUS Todo"
    },
    "fileAssociations": [
      {
        "ext": "todo",
        "name": "HIUS Todo Workspace",
        "description": "HIUS Todo Workspace",
        "role": "Editor"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "JongWoo-Woo1",
        "repo": "todo-hius",
        "releaseType": "release"
      }
    ],
    "artifactName": "HIUS-Todo-Setup-${version}-${arch}.${ext}"
  }
}
