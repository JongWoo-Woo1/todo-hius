{
  "name": "project-todo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electronmon dist-electron/main.js\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "build:web": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electronmon": "^2.0.4",
    "typescript": "^5.8.3",
    "vite": "^7.1.0",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
